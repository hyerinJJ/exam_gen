# Copy this file and rename the copy to ".env".
# Then fill in your real project id and API key.
#
# Default setup:
# - Google Cloud Vertex AI for Gemini
# - Anthropic Claude API for Claude

# Gemini through Google Cloud Vertex AI
GCP_PROJECT_ID=your-google-cloud-project-id
GCP_LOCATION=us-central1

# Claude API key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Alternative setup:
# If you do not use Google Cloud Vertex AI, remove or comment out GCP_PROJECT_ID
# and use a Gemini API key instead.
# GEMINI_API_KEY=your-gemini-api-key

# Optional: Claude model override
# CLAUDE_MODEL=claude-sonnet-4-6
